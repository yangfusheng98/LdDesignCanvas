<ControlTemplate TargetType="local:LdDesignCanvas">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <local:TopRuler x:Name="PART_TopRuler" Grid.Row="0" />
        <local:LayoutCanvas x:Name="PART_LayoutCanvas" Grid.Row="1">
            <local:PaperCanvas x:Name="PART_PaperCanvas" />
        </local:LayoutCanvas>
        <ScrollBar x:Name="PART_HScrollBar" Orientation="Horizontal" Grid.Row="1" />
        <ScrollBar x:Name="PART_VScrollBar" Orientation="Vertical" Grid.Row="1" />
    </Grid>
</ControlTemplate>