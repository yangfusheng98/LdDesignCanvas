<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:LdDesignCanvas.Controls">

    <!-- LdDesignCanvas 默认样式与控件模板 -->
    <Style TargetType="{x:Type local:LdDesignCanvas}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Gray" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LdDesignCanvas}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- 左侧标尺列 -->
                                <ColumnDefinition Width="25" />
                                <!-- 中间内容区 -->
                                <ColumnDefinition Width="*" />
                                <!-- 右侧垂直滚动条 -->
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <!-- 顶部标尺行 -->
                                <RowDefinition Height="25" />
                                <!-- 中间内容区 -->
                                <RowDefinition Height="*" />
                                <!-- 底部水平滚动条 -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 左上角空白区域 -->
                            <Border Grid.Row="0" Grid.Column="0"
                                    Background="{Binding RulerBackground, RelativeSource={RelativeSource TemplatedParent}}" />

                            <!-- 顶部 X 标尺 -->
                            <local:LdRulerElement x:Name="PART_TopRuler"
                                                Grid.Row="0" Grid.Column="1"
                                                Orientation="Horizontal"
                                                ClipToBounds="True" />

                            <!-- 左侧 Y 标尺 -->
                            <local:LdRulerElement x:Name="PART_LeftRuler"
                                                Grid.Row="1" Grid.Column="0"
                                                Orientation="Vertical"
                                                ClipToBounds="True" />

                            <!-- 中间设计内容区域（裁切容器） -->
                            <Border x:Name="PART_ContentArea"
                                    Grid.Row="1" Grid.Column="1"
                                    ClipToBounds="True"
                                    Background="{Binding CanvasBackground, RelativeSource={RelativeSource TemplatedParent}}">
                                <!-- 全局设计区域 Canvas -->
                                <Canvas x:Name="PART_LayoutCanvas">
                                    <!-- 纸张外围边框（背景色、阴影） -->
                                    <Border x:Name="PART_PaperBorder"
                                            Background="#fdfbc2"
                                            CornerRadius="0">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.4" Color="Black" />
                                        </Border.Effect>
                                        <!-- 纸张设计区域 Canvas -->
                                        <Canvas x:Name="PART_PaperCanvas">
                                            <!-- 打印标签边框（最底层，黑边白背景，支持圆角） -->
                                            <Border x:Name="PART_LabelBorder"
                                                    BorderBrush="Black"
                                                    BorderThickness="0.2"
                                                    Background="White"
                                                    Panel.ZIndex="-1" />
                                        </Canvas>
                                    </Border>
                                </Canvas>
                            </Border>

                            <!-- 右侧垂直滚动条 -->
                            <ScrollBar x:Name="PART_VScrollBar"
                                       Grid.Row="1" Grid.Column="2"
                                       Orientation="Vertical"
                                       Minimum="0" Maximum="100"
                                       SmallChange="1" LargeChange="10" />

                            <!-- 底部水平滚动条 -->
                            <ScrollBar x:Name="PART_HScrollBar"
                                       Grid.Row="2" Grid.Column="1"
                                       Orientation="Horizontal"
                                       Minimum="0" Maximum="100"
                                       SmallChange="1" LargeChange="10" />

                            <!-- 右下角空白区域 -->
                            <Border Grid.Row="2" Grid.Column="2"
                                    Background="{Binding RulerBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
