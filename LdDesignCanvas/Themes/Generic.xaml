<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LdDesignCanvas">

    <Style TargetType="{x:Type local:LdDesignCanvas}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="WorkspaceBackground" Value="#FFF0F0F0" />
        <Setter Property="PaperBackground" Value="White" />
        <Setter Property="PaperBorderBrush" Value="#FFBFBFBF" />
        <Setter Property="RulerBackground" Value="#FFF8F8F8" />
        <Setter Property="RulerTickBrush" Value="#FF7A7A7A" />
        <Setter Property="RulerTextBrush" Value="#FF303030" />
        <Setter Property="RulerBorderBrush" Value="#FFD0D0D0" />
        <Setter Property="RulerThickness" Value="28" />
        <Setter Property="RulerFontSize" Value="10" />
        <Setter Property="GridDotBrush" Value="#FFB9B9B9" />
        <Setter Property="GridDotSize" Value="0.25" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LdDesignCanvas}">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Row="0"
                                Grid.Column="0"
                                Background="{TemplateBinding RulerBackground}"
                                BorderBrush="{TemplateBinding RulerBorderBrush}"
                                BorderThickness="0,0,1,1" />

                            <Canvas
                                x:Name="PART_TopRuler"
                                Grid.Row="0"
                                Grid.Column="1"
                                ClipToBounds="True"
                                Background="{TemplateBinding RulerBackground}"
                                Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}" />

                            <Canvas
                                x:Name="PART_LeftRuler"
                                Grid.Row="1"
                                Grid.Column="0"
                                ClipToBounds="True"
                                Background="{TemplateBinding RulerBackground}"
                                Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}" />

                            <Border
                                x:Name="PART_ViewportHost"
                                Grid.Row="1"
                                Grid.Column="1"
                                Background="{TemplateBinding WorkspaceBackground}"
                                ClipToBounds="True">
                                <Canvas x:Name="PART_LayoutCanvas" ClipToBounds="False">
                                    <Border
                                        x:Name="PART_PaperHost"
                                        Background="{TemplateBinding PaperBackground}"
                                        BorderBrush="{TemplateBinding PaperBorderBrush}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                        <Grid ClipToBounds="True">
                                            <Canvas x:Name="PART_GridLayer" IsHitTestVisible="False" />
                                            <Canvas x:Name="PART_PaperCanvas" Background="Transparent" ClipToBounds="True" />
                                        </Grid>
                                    </Border>
                                </Canvas>
                            </Border>

                            <ScrollBar
                                x:Name="PART_VScrollBar"
                                Grid.Row="1"
                                Grid.Column="2"
                                Minimum="0"
                                Maximum="0"
                                Orientation="Vertical"
                                SmallChange="1"
                                Width="{x:Static SystemParameters.VerticalScrollBarWidth}" />

                            <ScrollBar
                                x:Name="PART_HScrollBar"
                                Grid.Row="2"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="0"
                                Orientation="Horizontal"
                                SmallChange="1"
                                Height="{x:Static SystemParameters.HorizontalScrollBarHeight}" />

                            <Border
                                Grid.Row="2"
                                Grid.Column="2"
                                Background="{TemplateBinding RulerBackground}"
                                BorderBrush="{TemplateBinding RulerBorderBrush}"
                                BorderThickness="1,1,0,0" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
