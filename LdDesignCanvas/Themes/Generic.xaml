<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LdDesignCanvas">

    <Style TargetType="{x:Type local:LdDesignCanvas}">
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Background" Value="{x:Static SystemColors.ControlBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LdDesignCanvas}">
                    <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ScrollBarThickness}" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ScrollBarThickness}" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="{TemplateBinding RulerBackground}"
                                BorderBrush="{TemplateBinding RulerTickBrush}"
                                BorderThickness="0,0,1,1" />

                        <Canvas x:Name="PART_TopRuler"
                                Grid.Row="0"
                                Grid.Column="1"
                                Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}"
                                Background="{TemplateBinding RulerBackground}"
                                ClipToBounds="True" />

                        <Canvas x:Name="PART_LeftRuler"
                                Grid.Row="1"
                                Grid.Column="0"
                                Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=RulerThickness}"
                                Background="{TemplateBinding RulerBackground}"
                                ClipToBounds="True" />

                        <Border x:Name="PART_Viewport"
                                Grid.Row="1"
                                Grid.Column="1"
                                Background="{TemplateBinding WorkspaceBackground}"
                                ClipToBounds="True">
                            <Canvas x:Name="PART_LayoutCanvas"
                                    Background="{TemplateBinding WorkspaceBackground}">
                                <Canvas x:Name="PART_PaperCanvas" />
                            </Canvas>
                        </Border>

                        <ScrollBar x:Name="PART_HScrollBar"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Orientation="Horizontal"
                                   Minimum="0" />

                        <ScrollBar x:Name="PART_VScrollBar"
                                   Grid.Row="1"
                                   Grid.Column="2"
                                   Orientation="Vertical"
                                   Minimum="0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
